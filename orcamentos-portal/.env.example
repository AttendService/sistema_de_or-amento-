# ============================================================
# Portal de Orçamentos — Variáveis Docker Compose
# Copie para .env na raiz do projeto antes de rodar docker compose up
# ============================================================

# Seleção do nginx no compose:
# - nginx.local.conf -> ambiente local sem TLS
# - nginx.prod.conf  -> redirecionamento 80 -> 443 + TLS
NGINX_CONF=nginx.local.conf

# Banco de dados (usado por postgres e backend)
POSTGRES_USER=orcamentos_user
POSTGRES_PASSWORD=
POSTGRES_DB=orcamentos_db

# JWT (obrigatório, mínimo 32 chars)
JWT_SECRET=

# Ambiente backend
NODE_ENV=production

# CORS no backend (domínio público da aplicação)
CORS_ORIGIN=https://seu-dominio.com.br

# Variável de frontend para build (opcional)
# Em produção via nginx reverso, normalmente deixe vazio.
VITE_API_URL=

# Referência da conexão backend (gerada automaticamente pelo compose):
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# Redis interno:
# REDIS_URL=redis://redis:6379
