# ============================================================
# Portal de Orçamentos — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# NUNCA commite o arquivo .env no repositório
# ============================================================

# Banco de dados
DATABASE_URL="postgresql://orcamentos_user:SUA_SENHA_AQUI@localhost:5432/orcamentos_db"

# JWT — use um segredo com pelo menos 32 caracteres aleatórios
# Gere com: openssl rand -hex 32
JWT_SECRET=""

# Servidor
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# CORS — URL do frontend
CORS_ORIGIN=http://localhost:5173

# Rate limiting (requisições por minuto por IP)
RATE_LIMIT_MAX=200

# Redis (para filas — sessão 3+)
REDIS_URL=redis://localhost:6379

# Email (para notificações — sessão futura)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=SENHA_SMTP
SMTP_FROM="Portal de Orçamentos <noreply@example.com>"

# Seed local de super admin (opcional)
ADMIN_NAME="Super Admin Local"
ADMIN_EMAIL=superadmin@local.test
ADMIN_PASSWORD=Admin@123456
