{
  "name": "orcamentos-portal-backend",
  "version": "1.0.0",
  "description": "Portal de Orçamentos — Backend API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "db:migrate": "prisma db execute --file prisma/migrations/001_initial_schema.sql --schema prisma/schema.prisma",
    "db:seed": "prisma db execute --file prisma/migrations/002_seed.sql --schema prisma/schema.prisma",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "prisma:gen": "prisma generate",
    "prisma:studio": "prisma studio",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "prisma": "^5.10.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  }
}
